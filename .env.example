# LokiDoki Environment Variables
# Copy this to .env and fill in the values

# Secret key for JWT signing (REQUIRED for production)
LOKIDOKI_JWT_SECRET=your-secret-key-here

# Default admin credentials (used during initial bootstrap/setup)
# If providing these here, the installer will skip the setup screen
# LOKIDOKI_ADMIN_USERNAME=admin
# LOKIDOKI_ADMIN_PASSWORD=your-complex-password-here

# Optional: override data directory (defaults to .lokidoki in root)
# LOKIDOKI_DATA_DIR=./data

# Optional: override host/port
# LOKIDOKI_HOST=127.0.0.1
# LOKIDOKI_PORT=8008
