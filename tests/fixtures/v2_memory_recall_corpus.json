{
  "$schema": "v2 memory recall corpus — multi-turn dialogues where turn N's correct outcome requires recalling facts written in earlier turns. Drives M2 (Tier 4 read), and will be extended in M3 (Tier 5 read) and M4 (Tier 2/3 read). Names use pop-culture characters per CLAUDE.md mock-data rule. Populated 2026-04-11 (M2) — 18 cases targeting Tier 4 retrieval with the FTS5 + RRF reader.",
  "version": 2,
  "phase_owner": "M2-M4",
  "case_schema": {
    "id": "string — stable, hierarchical (e.g. 'm2.recall.preference_color')",
    "phase": "integer — which phase ships the test (2, 3, or 4)",
    "owner_user_id": "integer — non-zero so cross-user isolation tests can swap",
    "writes": [
      {
        "subject": "string — 'self' or 'person:Name' or 'handle:my X'",
        "predicate": "string",
        "value": "string",
        "source_text": "string"
      }
    ],
    "query": "string — the recall query the test runs against the writes",
    "expect": {
      "min_hits": "integer — minimum number of hits",
      "max_hits": "integer|null — optional upper bound",
      "must_include_predicates": "array of strings — predicates that must appear in the hit set",
      "must_include_values": "array of strings — values that must appear (case-insensitive substring)",
      "must_not_include_subjects": "array of strings — subjects that must NOT leak in",
      "slot_must_contain": "string|null — substring that must appear in the rendered {user_facts} slot",
      "slot_max_chars": "integer — must be <= 250 per design §4"
    }
  },
  "cases": [
