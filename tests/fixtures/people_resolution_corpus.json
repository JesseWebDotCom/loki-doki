{
  "$schema": "v2 people resolution corpus — utterances paired with expected resolution outcomes against a seed roster. Each case feeds resolve_person() and asserts the matched person, ambiguity flag, and the matched_via strategy. Drives M3 top-1 accuracy gate, provisional handle merge tests, and cross-user isolation guarantees. Names use pop-culture characters per CLAUDE.md mock-data rule. Populated 2026-04-11 (M3) — 32 cases across exact / handle / substring / fuzzy / ambiguous / merge / isolation / no-match buckets.",
  "version": 2,
  "phase_owner": "M3",
  "case_schema": {
    "id": "string — stable, hierarchical (e.g. 'm3.exact.luke_first_name')",
    "bucket": "string — exact | handle | substring | fuzzy | ambiguous | merge | isolation | no_match",
    "owner_user_id": "integer — non-zero so cross-user isolation tests can swap",
    "seed": [
      {
        "subject": "string — 'person:Name' or 'handle:my X'",
        "predicate": "string — is_relation, is_named, has_pronoun, lives_in, has_birthday",
        "value": "string"
      }
    ],
    "mention": "string — the value passed to resolve_person()",
    "expect": {
      "matched": "string|null — name (or 'handle:my boss') of the expected match, null when no match",
      "matched_via": "string|null — name | handle | name_substring | alias_fuzzy | recency",
      "ambiguous": "boolean",
      "min_candidates": "integer",
      "reason_contains": "string|null — substring expected in PersonResolution.reason",
      "post_merge_name": "string|null — for merge cases, the expected name after merge",
      "post_merge_provisional": "boolean|null — for merge cases, expected provisional flag after merge"
    }
  },
  "cases": [
