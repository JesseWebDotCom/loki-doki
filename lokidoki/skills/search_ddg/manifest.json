{
  "skill_id": "search_ddg",
  "name": "DuckDuckGo Search",
  "is_searchable": true,
  "search_config": {
    "corpus_target": "response_body",
    "budget_tokens": 1500
  },
  "intents": ["search_web", "search_news"],
  "description": "General web search via DuckDuckGo. Use it for current events, news, or anything not covered by Wikipedia.",
  "examples": [
    "search the web for raspberry pi 5 reviews",
    "what's the latest news about NASA",
    "find recipes for sourdough bread"
  ],
  "parameters": {
    "query": {"type": "string", "required": true}
  },
  "mechanisms": [
    {
      "method": "ddg_api",
      "priority": 1,
      "timeout_ms": 5000,
      "requires_internet": true
    },
    {
      "method": "ddg_scraper",
      "priority": 2,
      "timeout_ms": 8000,
      "requires_internet": true
    }
  ]
}
