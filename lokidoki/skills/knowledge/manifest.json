{
  "skill_id": "knowledge",
  "name": "Wikipedia Knowledge Engine",
  "is_searchable": true,
  "search_config": {
    "corpus_target": "response_body",
    "budget_tokens": 1000
  },
  "intents": ["search_knowledge", "get_summary"],
  "categories": ["encyclopedia"],
  "description": "Looks up factual summaries from Wikipedia. Best for definitions, biographies, places, and historical events.",
  "examples": [
    "who is Alan Turing",
    "what is the Eiffel Tower",
    "tell me about black holes",
    "summarize the French Revolution"
  ],
  "parameters": {
    "query": {"type": "string", "required": true}
  },
  "mechanisms": [
    {
      "method": "mediawiki_api",
      "priority": 1,
      "timeout_ms": 3000,
      "requires_internet": true
    },
    {
      "method": "web_scraper",
      "priority": 2,
      "timeout_ms": 5000,
      "requires_internet": true
    }
  ]
}
