# Copy to `.pi.env` and fill in any overrides you want to keep local.
# `.pi.env` is gitignored.

# SSH target
PI_USER=pi
PI_PORT=22
PI_HOST=your-pi-host-or-local-dns-name

# Optional SSH identity file. Leave blank to use your agent/default SSH config.
PI_SSH_KEY=

# Remote repo location on the Pi
PI_REMOTE_DIR=~/loki-doki

# Extra SSH options if needed, for example:
# PI_SSH_EXTRA_OPTS="-o StrictHostKeyChecking=accept-new"
PI_SSH_EXTRA_OPTS=
